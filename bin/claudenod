#!/usr/bin/env python3

import argparse
import json
import os
import pty
import re
import select
import signal
import socket
import subprocess
import sys
import termios
import time
import tty
import uuid
from pathlib import Path
from tempfile import NamedTemporaryFile


APP_SUPPORT = Path.home() / "Library" / "Application Support" / "ClaudeNod"
STATE_FILE = APP_SUPPORT / "bridge-state.json"
SOCKET_FILE = APP_SUPPORT / "bridge.sock"

CONFIRMATION_HINTS = [
    "should i proceed",
    "confirm",
    "what would you like me to confirm",
    "yes, proceed",
    "no, cancel",
    "enter to select",
    "to navigate",
    "esc to cancel",
    "approve",
    "allow this action",
]


def strip_ansi(text: str) -> str:
    text = re.sub(r"\x1b\[[0-?]*[ -/]*[@-~]", "", text)
    text = re.sub(r"\x1b\][^\x07\x1b]*(?:\x07|\x1b\\)", "", text)
    text = re.sub(r"[\x00-\x08\x0b-\x1f\x7f]", "", text)
    return text


def normalize_preview(text: str) -> str:
    compact = " ".join(text.split())
    return compact[:220] if compact else "No readable Claude output yet"


def build_state(
    session_id: str,
    pid: int,
    prompt_visible: bool,
    evidence: str,
    preview: str,
    guidance: str | None,
    nod_sequence: list[str] | None,
    shake_sequence: list[str] | None,
) -> dict:
    return {
        "sessionID": session_id,
        "pid": pid,
        "hostName": "Claude wrapper",
        "promptVisible": prompt_visible,
        "evidence": evidence,
        "preview": preview,
        "guidance": guidance,
        "nodSequence": nod_sequence,
        "shakeSequence": shake_sequence,
        "updatedAt": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
    }


def write_state(state: dict) -> None:
    APP_SUPPORT.mkdir(parents=True, exist_ok=True)
    with NamedTemporaryFile("w", encoding="utf-8", dir=APP_SUPPORT, prefix="bridge-state-", suffix=".tmp", delete=False) as tmp_file:
        tmp_file.write(json.dumps(state))
        temp_path = Path(tmp_file.name)
    temp_path.replace(STATE_FILE)


def clear_state() -> None:
    for path in [STATE_FILE, SOCKET_FILE]:
        try:
            path.unlink()
        except FileNotFoundError:
            pass


def extract_menu_options(text: str) -> tuple[list[tuple[int, str]], int | None]:
    options: list[tuple[int, str]] = []
    selected_index: int | None = None
    lines = text.splitlines()

    for line in lines[-80:]:
        stripped = line.strip()
        if not stripped:
            continue

        selected = stripped.startswith(">")
        if selected:
            stripped = stripped[1:].strip()

        match = re.match(r"(\d+)\.\s+(.+)", stripped)
        if not match:
            continue

        index = int(match.group(1))
        label = " ".join(match.group(2).split())
        if not label:
            continue

        options.append((index, label))
        if selected:
            selected_index = index

    unique: list[tuple[int, str]] = []
    seen: set[int] = set()
    for index, label in options:
        if index in seen:
            continue
        seen.add(index)
        unique.append((index, label))

    return unique, selected_index


def sequence_for_option(target_index: int, selected_index: int | None) -> list[str]:
    del selected_index
    return [str(target_index), "\r"]


def detect_prompt(buffer_text: str) -> tuple[bool, str, str, str | None, str | None, str | None]:
    raw = strip_ansi(buffer_text)
    cleaned = raw.lower()
    preview = normalize_preview(cleaned[-2000:])
    menu_options, selected_index = extract_menu_options(raw)

    if len(menu_options) >= 2 and "enter to select" in cleaned:
        option1 = menu_options[0]
        option2 = menu_options[1]
        guidance = f"Nod: 1. {option1[1]} | Shake: 2. {option2[1]}"
        nod_sequence = sequence_for_option(option1[0], selected_index)
        shake_sequence = sequence_for_option(option2[0], selected_index)
        return True, "Detected numbered choice prompt", preview, guidance, nod_sequence, shake_sequence

    for hint in CONFIRMATION_HINTS:
        if hint in cleaned:
            return True, hint, preview, "Nod: accept | Shake: reject", ["y", "\r"], ["n", "\r"]
    return False, "Watching Claude output", preview, None, None, None


def resolve_claude_command(explicit_command: str | None) -> list[str]:
    if explicit_command:
        return [explicit_command]
    return ["claude"]


def main() -> int:
    parser = argparse.ArgumentParser(description="Launch Claude through ClaudeNod's local bridge.")
    parser.add_argument("--command", help="Path to the Claude executable to launch.")
    parser.add_argument("args", nargs=argparse.REMAINDER, help="Arguments passed through to Claude.")
    parsed = parser.parse_args()

    command = resolve_claude_command(parsed.command)
    passthrough = parsed.args
    if passthrough and passthrough[0] == "--":
        passthrough = passthrough[1:]

    argv = command + passthrough

    APP_SUPPORT.mkdir(parents=True, exist_ok=True)
    clear_state()

    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    server.bind(str(SOCKET_FILE))
    server.listen(1)
    server.setblocking(False)

    session_id = str(uuid.uuid4())
    master_fd, child_fd = pty.openpty()
    child = subprocess.Popen(argv, stdin=child_fd, stdout=child_fd, stderr=child_fd, close_fds=True)
    os.close(child_fd)

    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()
    old_tty = termios.tcgetattr(stdin_fd)
    tty.setraw(stdin_fd)

    signal.signal(signal.SIGINT, lambda *_: child.send_signal(signal.SIGINT))
    signal.signal(signal.SIGTERM, lambda *_: child.send_signal(signal.SIGTERM))

    buffer = ""
    last_publish = 0.0

    try:
        while True:
            prompt_visible, evidence, preview, guidance, nod_sequence, shake_sequence = detect_prompt(buffer)
            now = time.time()
            if now - last_publish > 0.35:
                write_state(
                    build_state(
                        session_id,
                        child.pid,
                        prompt_visible,
                        evidence,
                        preview,
                        guidance,
                        nod_sequence,
                        shake_sequence,
                    )
                )
                last_publish = now

            if child.poll() is not None:
                break

            readable, _, _ = select.select([stdin_fd, master_fd, server], [], [], 0.1)

            if server in readable:
                conn, _ = server.accept()
                with conn:
                    conn.setblocking(True)
                    try:
                        payload = conn.recv(8192)
                    except BlockingIOError:
                        payload = b""
                    if payload:
                        try:
                            message = json.loads(payload.decode("utf-8"))
                            if message.get("kind") == "send_sequence":
                                for chunk in message.get("payloads", []):
                                    os.write(master_fd, chunk.encode("utf-8"))
                                    time.sleep(0.04)
                        except json.JSONDecodeError:
                            pass

            if stdin_fd in readable:
                data = os.read(stdin_fd, 8192)
                if data:
                    os.write(master_fd, data)

            if master_fd in readable:
                data = os.read(master_fd, 8192)
                if not data:
                    break
                os.write(stdout_fd, data)
                decoded = data.decode("utf-8", errors="ignore")
                buffer = (buffer + decoded)[-12000:]
    finally:
        termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_tty)
        clear_state()
        try:
            server.close()
        except OSError:
            pass
        try:
            os.close(master_fd)
        except OSError:
            pass

    return child.wait()


if __name__ == "__main__":
    raise SystemExit(main())
